    <string name="desc_stoolkit_ai">Multi-model native AI for writing, coding, and planning anything.</string>
    <string name="desc_auto_tts">Multilingual text-to-speech with automatic language detection and synthesis.</string>
    <string name="desc_audio_video_transcriber">Transcribe your audio and video files accurately using AI.</string>
    <string name="desc_youtube_toolkit">Download, summarize, and transcribe YouTube videos effortlessly.</string>
    <string name="desc_ai_image_generator">Generate and edit stunning images using advanced AI technology.</string>
    <string name="desc_ai_image_analysis">Analyze images with AI to extract insights and information.</string>
